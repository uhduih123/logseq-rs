{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/tauri-v2/refs/heads/main/crates/tauri-cli/schema.json",
  "productName": "Logseq RS",
  "version": "0.1.0",
  "identifier": "com.logseq-rs.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "Logseq RS",
    "windows": [
      {
        "title": "Logseq RS",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
